module tailscale.dns.preferences

import "@formae/formae.pkl"
import "../tailscale.pkl"

const type = "TAILSCALE::DNS::Preferences"

open class DNSPreferencesResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden tailnet: DNSPreferencesResolvable = (this) { property = "tailnet" }
}

@tailscale.ResourceHint {
    type = module.type
    identifier = "tailnet"
    portable = true
}
open class DNSPreferences extends formae.Resource {
    @tailscale.FieldHint { hasProviderDefault = true }
    tailnet: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    magicDNS: Boolean?

    local parent = this

    hidden res: DNSPreferencesResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
