module tailscale.dns.nameservers

import "@formae/formae.pkl"
import "../tailscale.pkl"

const type = "TAILSCALE::DNS::Nameservers"

open class DNSNameserversResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden tailnet: DNSNameserversResolvable = (this) { property = "tailnet" }
}

@tailscale.ResourceHint {
    type = module.type
    identifier = "tailnet"
    portable = true
}
open class DNSNameservers extends formae.Resource {
    @tailscale.FieldHint { hasProviderDefault = true }
    tailnet: String?

    @tailscale.FieldHint { required = true }
    nameservers: Listing<String>

    local parent = this

    hidden res: DNSNameserversResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
