module tailscale.iam.federated_identity

import "@formae/formae.pkl"
import "../tailscale.pkl"

const type = "TAILSCALE::IAM::FederatedIdentity"

open class FederatedIdentityResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden id: FederatedIdentityResolvable = (this) { property = "id" }
    hidden key: FederatedIdentityResolvable = (this) { property = "key" }
}

@tailscale.ResourceHint {
    type = module.type
    identifier = "id"
    portable = true
}
open class FederatedIdentity extends formae.Resource {
    @tailscale.FieldHint { hasProviderDefault = true }
    description: String?

    @tailscale.FieldHint { required = true }
    scopes: Listing<String>

    @tailscale.FieldHint { hasProviderDefault = true }
    tags: Listing<String>?

    @tailscale.FieldHint { hasProviderDefault = true }
    audience: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    issuer: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    subject: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    customClaimRules: Mapping<String, String>?

    @tailscale.FieldHint { hasProviderDefault = true }
    id: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    key: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    createdAt: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    updatedAt: String?

    @tailscale.FieldHint { hasProviderDefault = true }
    userId: String?

    local parent = this

    hidden res: FederatedIdentityResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
