module tailscale.device.authorization

import "@formae/formae.pkl"
import "../tailscale.pkl"

const type = "TAILSCALE::Device::Authorization"

open class DeviceAuthorizationResolvable extends formae.Resolvable {
    hidden type = module.type

    hidden deviceId: DeviceAuthorizationResolvable = (this) { property = "deviceId" }
}

@tailscale.ResourceHint {
    type = module.type
    identifier = "deviceId"
    portable = true
}
open class DeviceAuthorization extends formae.Resource {
    @tailscale.FieldHint { required = true; createOnly = true }
    deviceId: String

    @tailscale.FieldHint { hasProviderDefault = true }
    authorized: Boolean?

    local parent = this

    hidden res: DeviceAuthorizationResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }
}
