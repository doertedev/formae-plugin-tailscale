/*
 * Formae Plugin Manifest
 *
 * This file defines metadata for your Formae plugin.
 * Update the values below to match your plugin.
 */

// Plugin name used as the directory name and binary name.
name = "tailscale"

version = "0.1.0"

// Namespace appears in resource type IDs as the uppercase prefix: <NAMESPACE>::<Module>::<Resource>.
namespace = "TAILSCALE"

summary = "Manage Tailscale auth keys, OAuth clients, federated identities, ACLs, tailnet settings, contacts, DNS, devices, services, posture, logging, and webhooks"

// Plugin description populated from --description at scaffold time.
description = "Formae resource plugin for Tailscale"

category = "network"

// SPDX license identifier (must be one of: Apache-2.0, BSD-3-Clause, MIT, MPL-2.0 for Hub publishability).
license = "Apache-2.0"

// Auto-generated by 'make build' from SDK. Do not edit manually.
minFormaeVersion = "0.86.1"

output {
  renderer = new JsonRenderer {}
}
