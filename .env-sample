# Tailscale plugin live-test credentials.
# Copy to .env for local testing. Use a dedicated test tailnet or test-scoped credentials.
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=-

# OAuth is supported by the plugin but API keys are the default test path.
# TAILSCALE_OAUTH_CLIENT_ID=
# TAILSCALE_OAUTH_CLIENT_SECRET=
# TAILSCALE_OAUTH_SCOPES=auth_keys:read,auth_keys:write,webhooks

# Optional test/debug controls.
# TAILSCALE_BASE_URL=
# TAILSCALE_PLUGIN_DEBUG=1
# TAILSCALE_CLEANUP_PREFIXES=formae-test-
